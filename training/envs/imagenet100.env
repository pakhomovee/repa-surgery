# ImageNet-100 dataset environment (100-class subset of ImageNet) for REPA.
#
# Uses the pre-packaged IN100 zip (default /root/autodl-pub/ImageNet100/
# imagenet100.zip), whose layout is  imagenet100/<wnid>/<wnid>_*.JPEG  (100 class
# folders, train split). That mount is READ-ONLY, so prepare_dataset() extracts
# into writable <repo>/data and converts + VAE-encodes from there. Override the
# zip path with IMAGENET100_ZIP.

DATASET_NAME="imagenet100"

DATA_DIR="../data/imagenet100_256"
NUM_CLASSES=100
RESOLUTION=256

DEFAULT_MODEL="SiT-B/2"   # bump to SiT-L/2 if the budget allows
ENC_TYPE="dinov2-vit-b"
PROJ_COEFF=0.5
ENCODER_DEPTH=4
PATH_TYPE="linear"
PREDICTION="v"
WEIGHTING="uniform"

DEFAULT_BATCH_SIZE=256
DEFAULT_NUM_WORKERS=4
DEFAULT_CHECKPOINTING_STEPS=20000
DEFAULT_MAX_TRAIN_STEPS=400000
DEFAULT_SAMPLING_STEPS=1000000

# Mode knobs (SiT-B sizes): HASTE termination + REPA-sigma EMA decay.
HASTE_END_STEP=100000
GRAD_EMA_DECAY=0.99

prepare_dataset() {
  local out="$REPO_ROOT/data/imagenet100_256"
  local zip="${IMAGENET100_ZIP:-/root/autodl-pub/ImageNet100/imagenet100.zip}"
  local extracted="$REPO_ROOT/data/imagenet100"   # zip contains a top-level imagenet100/

  # 1. Extract the read-only zip into writable data/ (once).
  if [[ ! -d "$extracted" || -z "$(ls -A "$extracted" 2>/dev/null)" ]]; then
    if [[ ! -f "$zip" ]]; then
      echo "[imagenet100] Zip not found: $zip (set IMAGENET100_ZIP)." >&2
      return 1
    fi
    echo "[imagenet100] Extracting $zip -> $REPO_ROOT/data ..."
    mkdir -p "$REPO_ROOT/data"
    unzip -q -n "$zip" -d "$REPO_ROOT/data"
  else
    echo "[imagenet100] Found $extracted, skipping unzip."
  fi

  # 2. Center-crop/resize to 256x256 (class label from the wnid folder name).
  if [[ ! -f "$out/images/dataset.json" ]]; then
    echo "[imagenet100] Converting $extracted -> $out/images ..."
    ( cd "$REPO_ROOT/REPA/preprocessing" && \
      python dataset_tools.py convert \
        --source "$extracted" \
        --dest "$out/images" \
        --resolution=256x256 \
        --transform=center-crop-dhariwal )
  else
    echo "[imagenet100] Found $out/images/dataset.json, skipping convert."
  fi

  # 3. Multi-GPU SD-VAE encode.
  if [[ ! -f "$out/vae-sd/dataset.json" ]]; then
    echo "[imagenet100] Encoding VAE latents to $out/vae-sd (GPUs: ${GPUS:-0}) ..."
    python "$REPO_ROOT/datasets/encode_vae.py" \
      --source "$out/images" \
      --dest "$out/vae-sd" \
      --model-url stabilityai/sd-vae-ft-mse \
      --gpus "${GPUS:-0}" \
      --batch-size "${ENCODE_BATCH_SIZE:-64}" \
      --num-workers "${ENCODE_NUM_WORKERS:-8}"
  else
    echo "[imagenet100] Found $out/vae-sd/dataset.json, skipping VAE encode."
  fi
}
