# CelebA dataset environment for REPA training.
#
# Sourced by training/train.sh. All paths here are interpreted relative to the
# REPA submodule working dir (train.py is launched from inside REPA/), except
# inside prepare_dataset() where $REPO_ROOT points at the repo root.
#
# Number of classes = 2 ^ (number of selected CelebA attributes).
# The default export uses 4 attributes (Male, Smiling, Young, Attractive) => 16.

DATASET_NAME="celeba"

# Where train.py reads {images/, vae-sd/} from (relative to REPA/).
DATA_DIR="../data/celeba256"
NUM_CLASSES=16
RESOLUTION=256

# ---- Default model + REPA representation-alignment settings ----------------
# Override any of these from the CLI (e.g. --model, --baseline).
DEFAULT_MODEL="SiT-B/2"
ENC_TYPE="dinov2-vit-b"   # encoder for alignment; "none" => plain SiT baseline
PROJ_COEFF=0.5            # alignment loss weight; ignored when ENC_TYPE=none
ENCODER_DEPTH=4
PATH_TYPE="linear"
PREDICTION="v"
WEIGHTING="uniform"

# ---- Default training scale (CLI overridable) ------------------------------
DEFAULT_BATCH_SIZE=256
DEFAULT_NUM_WORKERS=4
DEFAULT_CHECKPOINTING_STEPS=10000
DEFAULT_MAX_TRAIN_STEPS=100000
DEFAULT_SAMPLING_STEPS=1000000   # effectively "never" during training

# ---------------------------------------------------------------------------
# prepare_dataset: build $REPO_ROOT/data/celeba256/{images, dataset.json, vae-sd}
# Runs once; skips work that already exists. Note that DINOv2 features are NOT
# precomputed here on purpose -- REPA applies the encoder on-the-fly at train
# time, so the dataset only needs raw images + VAE latents.
# ---------------------------------------------------------------------------
prepare_dataset() {
  local out="$REPO_ROOT/data/celeba256"

  if [[ ! -f "$out/dataset.json" ]]; then
    echo "[celeba] Exporting images + labels to $out ..."
    python "$REPO_ROOT/datasets/export_celeba.py" \
      --output-dir "$out" \
      --resolution "$RESOLUTION"
  else
    echo "[celeba] Found $out/dataset.json, skipping image export."
  fi

  if [[ ! -d "$out/vae-sd" || -z "$(ls -A "$out/vae-sd" 2>/dev/null)" ]]; then
    echo "[celeba] Encoding VAE latents to $out/vae-sd ..."
    ( cd "$REPO_ROOT/REPA/preprocessing" && \
      python dataset_tools.py encode \
        --source "$out" \
        --dest "$out/vae-sd" \
        --model-url stabilityai/sd-vae-ft-mse )
  else
    echo "[celeba] Found $out/vae-sd, skipping VAE encode."
  fi
}
