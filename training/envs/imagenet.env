# ImageNet-256 dataset environment for REPA training.
#
# Requires ImageNet (ILSVRC2012 train) downloaded locally. Point IMAGENET_SRC at
# the class-folder train dir, e.g. .../ILSVRC/Data/CLS-LOC/train (1000 subdirs).
# prepare_dataset() then: (1) center-crops/resizes to 256 (REPA convert, the
# class label comes from the folder name), (2) encodes SD-VAE latents on $GPUS.

DATASET_NAME="imagenet"

DATA_DIR="../data/imagenet256"
NUM_CLASSES=1000
RESOLUTION=256

DEFAULT_MODEL="SiT-XL/2"
ENC_TYPE="dinov2-vit-b"
PROJ_COEFF=0.5
ENCODER_DEPTH=8
PATH_TYPE="linear"
PREDICTION="v"
WEIGHTING="uniform"

DEFAULT_BATCH_SIZE=256
DEFAULT_NUM_WORKERS=4
DEFAULT_CHECKPOINTING_STEPS=50000
DEFAULT_MAX_TRAIN_STEPS=400000
DEFAULT_SAMPLING_STEPS=1000000

# Mode knobs: HASTE termination (paper used 250k for L/XL); REPA-sigma EMA decay.
HASTE_END_STEP=250000
GRAD_EMA_DECAY=0.99

prepare_dataset() {
  local out="$REPO_ROOT/data/imagenet256"
  local src="${IMAGENET_SRC:-$REPO_ROOT/data/imagenet/ILSVRC/Data/CLS-LOC/train}"

  if [[ ! -d "$src" ]]; then
    echo "[imagenet] Source not found at $src." >&2
    echo "[imagenet] Set IMAGENET_SRC to your ILSVRC train dir and re-run." >&2
    return 1
  fi

  # (1) center-crop/resize to 256x256 (single-process; labels from folder names).
  if [[ ! -f "$out/images/dataset.json" ]]; then
    echo "[imagenet] Converting images to $out/images ..."
    ( cd "$REPO_ROOT/REPA/preprocessing" && \
      python dataset_tools.py convert \
        --source "$src" \
        --dest "$out/images" \
        --resolution=256x256 \
        --transform=center-crop-dhariwal )
  else
    echo "[imagenet] Found $out/images/dataset.json, skipping convert."
  fi

  # (2) multi-GPU SD-VAE encode (1.28M images -- use all of $GPUS).
  if [[ ! -f "$out/vae-sd/dataset.json" ]]; then
    echo "[imagenet] Encoding VAE latents to $out/vae-sd (GPUs: ${GPUS:-0}) ..."
    python "$REPO_ROOT/datasets/encode_vae.py" \
      --source "$out/images" \
      --dest "$out/vae-sd" \
      --model-url stabilityai/sd-vae-ft-mse \
      --gpus "${GPUS:-0}" \
      --batch-size "${ENCODE_BATCH_SIZE:-64}" \
      --num-workers "${ENCODE_NUM_WORKERS:-8}"
  else
    echo "[imagenet] Found $out/vae-sd/dataset.json, skipping VAE encode."
  fi
}
