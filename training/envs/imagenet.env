# ImageNet-256 dataset environment for REPA training (stub / template).
#
# Fill in prepare_dataset() once you have ImageNet downloaded. The REPA
# preprocessing path is:
#   1. dataset_tools.py convert --source <ILSVRC train> --dest <out>/images \
#        --resolution=256x256 --transform=center-crop-dhariwal
#   2. dataset_tools.py encode  --source <out>/images --dest <out>/vae-sd
# See REPA/preprocessing/README.md.

DATASET_NAME="imagenet"

DATA_DIR="../data/imagenet256"
NUM_CLASSES=1000
RESOLUTION=256

DEFAULT_MODEL="SiT-XL/2"
ENC_TYPE="dinov2-vit-b"
PROJ_COEFF=0.5
ENCODER_DEPTH=8
PATH_TYPE="linear"
PREDICTION="v"
WEIGHTING="uniform"

DEFAULT_BATCH_SIZE=256
DEFAULT_NUM_WORKERS=4
DEFAULT_CHECKPOINTING_STEPS=50000
DEFAULT_MAX_TRAIN_STEPS=400000
DEFAULT_SAMPLING_STEPS=1000000

prepare_dataset() {
  local out="$REPO_ROOT/data/imagenet256"
  local src="${IMAGENET_SRC:-$REPO_ROOT/data/imagenet/ILSVRC/Data/CLS-LOC/train}"

  if [[ ! -d "$src" ]]; then
    echo "[imagenet] Source not found at $src." >&2
    echo "[imagenet] Set IMAGENET_SRC to your ILSVRC train dir and re-run." >&2
    return 1
  fi

  if [[ ! -d "$out/images" || -z "$(ls -A "$out/images" 2>/dev/null)" ]]; then
    echo "[imagenet] Converting images to $out/images ..."
    ( cd "$REPO_ROOT/REPA/preprocessing" && \
      python dataset_tools.py convert \
        --source "$src" \
        --dest "$out/images" \
        --resolution=256x256 \
        --transform=center-crop-dhariwal )
  fi

  if [[ ! -d "$out/vae-sd" || -z "$(ls -A "$out/vae-sd" 2>/dev/null)" ]]; then
    echo "[imagenet] Encoding VAE latents to $out/vae-sd ..."
    ( cd "$REPO_ROOT/REPA/preprocessing" && \
      python dataset_tools.py encode \
        --source "$out/images" \
        --dest "$out/vae-sd" )
  fi
}
